# Doxyfile for ssd1306xled
# Minimal config -- only non-default values are listed.
# Run: doxygen Doxyfile

# Project metadata
PROJECT_NAME           = "ssd1306xled"
PROJECT_NUMBER         = "1.0.0"
PROJECT_BRIEF          = "SSD1306/SSD1315/SSH1106 OLED driver for ATtiny85"
PROJECT_LOGO           =

# Output
OUTPUT_DIRECTORY       = docs
GENERATE_HTML          = YES
GENERATE_LATEX         = NO
HTML_OUTPUT            = html

# Input files
INPUT                  = README.md \
                         ssd1306xled.h \
                         ssd1306xled.cpp \
                         docs/pages
RECURSIVE              = YES
FILE_PATTERNS          = *.h *.cpp *.md
USE_MDFILE_AS_MAINPAGE = README.md
EXAMPLE_PATH           = examples
IMAGE_PATH             = images \
                         examples/OLED_demo \
                         examples/sprite_overlap_fix \
                         examples/invaders_fix \
                         examples/tiny_gilbert \
                         examples/tiny_space_invaders \
                         examples/tiny_bomber

# Extraction
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = NO

# Preprocessing -- define DOXYGEN so @def blocks inside #ifdef DOXYGEN are documented
ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES
EXPAND_ONLY_PREDEF     = YES
PREDEFINED             = DOXYGEN

# C++ / Arduino
OPTIMIZE_OUTPUT_FOR_C  = YES

# HTML appearance (doxygen-awesome-css theme)
HTML_HEADER            = docs/header.html
HTML_EXTRA_STYLESHEET  = docs/doxygen-awesome-css/doxygen-awesome.css \
                         docs/doxygen-awesome-css/doxygen-awesome-sidebar-only.css \
                         docs/doxygen-awesome-css/doxygen-awesome-sidebar-only-darkmode-toggle.css \
                         docs/custom.css
HTML_EXTRA_FILES       = docs/doxygen-awesome-css/doxygen-awesome-darkmode-toggle.js \
                         docs/doxygen-awesome-css/doxygen-awesome-fragment-copy-button.js \
                         docs/doxygen-awesome-css/doxygen-awesome-paragraph-link.js \
                         docs/doxygen-awesome-css/doxygen-awesome-interactive-toc.js
SEARCHENGINE           = YES
GENERATE_TREEVIEW      = YES
FULL_SIDEBAR           = NO
HTML_COLORSTYLE        = LIGHT
DISABLE_INDEX          = NO
TREEVIEW_WIDTH         = 335

# Warnings
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
# Misc
QUIET                  = YES
MARKDOWN_SUPPORT       = YES
AUTOLINK_SUPPORT       = YES
